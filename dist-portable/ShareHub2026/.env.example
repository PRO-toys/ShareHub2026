# ShareHub2026 Configuration
# Copy this file to .env and edit values

# Server ports (avoid 3100 = Booth server)
PORT=3200
HTTPS_PORT=3543

# Path to Booth project folder (contains BackUp/Series/)
# Example: C:\Users\Fujitsu\Desktop\01
WATCH_FOLDER=

# Firebase (optional — for cloud sync)
# Path to firebase-adminsdk JSON file
FIREBASE_KEY=
FIREBASE_PROJECT_ID=photobooth-3a08f
FIREBASE_BUCKET=photobooth-3a08f.firebasestorage.app

# Cloud URL for QR codes (Firebase Hosting)
QR_BASE_URL=https://photobooth-3a08f.web.app

# QR settings
QR_TOKEN_LENGTH=12
QR_EXPIRY_HOURS=24

# Face Search (InsightFace service URL)
FACE_SERVICE_URL=http://localhost:3101

# CORS (comma separated origins, empty = allow all)
CORS_ORIGINS=

# Storage path (default: ./storage/)
# STORAGE_PATH=
